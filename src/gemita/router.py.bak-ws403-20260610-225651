import logging
import uuid

from litestar import websocket
from litestar.connection import WebSocket

log = logging.getLogger("aurora.gemita")

WORKSPACE_ROOT = "/media/almacen/deml/Downloads/core_instruction"


async def _send(socket: WebSocket, payload: dict) -> None:
    await socket.send_json(payload)


@websocket("/gemita")
async def gemita_ws(socket: WebSocket) -> None:
    await socket.accept()

    session_id = "gemita-" + uuid.uuid4().hex[:8]
    session_name = "Aurora Gemita v2"

    await _send(socket, {
        "type": "session_init",
        "session_id": session_id,
        "session_name": session_name,
        "session_path": "/gemita",
        "workspace": WORKSPACE_ROOT,
    })
    await _send(socket, {
        "type": "status",
        "status": "ready",
        "mode": "stub",
        "session_id": session_id,
        "session_name": session_name,
        "session_path": "/gemita",
        "workspace": WORKSPACE_ROOT,
    })

    while True:
        try:
            msg = await socket.receive_json()
        except Exception:
            break

        if not isinstance(msg, dict):
            await _send(socket, {"type": "error", "message": "Mensaje no JSON"})
            continue

        msg_type = msg.get("type")

        if msg_type == "models":
            await _send(socket, {
                "type": "models",
                "models": [],
                "mode": "stub",
            })
            continue

        if msg_type == "reset":
            await _send(socket, {
                "type": "status",
                "status": "reset",
                "mode": "stub",
                "session_id": session_id,
                "session_name": session_name,
                "session_path": "/gemita",
                "workspace": WORKSPACE_ROOT,
            })
            continue

        if msg_type == "chat":
            await _send(socket, {
                "type": "thinking",
                "content": "Gemita v2 está montada en /gemita. Falta conectar el runtime local.",
            })
            await _send(socket, {
                "type": "token",
                "content": "Gemita está viva dentro del servidor Aurora :7779, pero todavía no está conectada a llama.cpp/Ollama.",
            })
            await _send(socket, {
                "type": "done",
                "mode": "stub",
            })
            continue

        if msg_type in {"confirm", "hub_action_result"}:
            await _send(socket, {
                "type": "status",
                "status": "ignored",
                "mode": "stub",
                "session_id": session_id,
            })
            continue

        await _send(socket, {
            "type": "error",
            "message": "Tipo de mensaje no soportado por Gemita stub: " + str(msg_type),
        })


GEMITA_ROUTES = [gemita_ws]
